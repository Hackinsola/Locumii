# Copy this file to .env and fill in the values. Never commit .env.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Supabase project API URL (Settings -> API -> Project URL).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable client key — safe to expose in the browser.
# Accepts the modern sb_publishable_... key or the legacy anon JWT.
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Paystack PUBLIC key — safe to expose in the browser (used by the inline popup).
# Use the pk_test_... key while developing; pk_live_... only for production.
# The SECRET key (sk_...) is NEVER placed here or anywhere in src/ — it is set as a
# Supabase Edge Function secret (PAYSTACK_SECRET_KEY); see Context/progress-tracker.md.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# Google Analytics 4 Measurement ID (Analytics → Admin → Data streams → your web
# stream → "Measurement ID", format G-XXXXXXXXXX). Optional — analytics only loads
# when this is set, so leave it blank in dev. Set it as a Vercel env var for prod.
VITE_GA_MEASUREMENT_ID=

# --- Notifications / SMS (server-side only — NOT client env) ---------------------
# These are NOT VITE_ vars and must never appear in src/. The SMS path runs entirely
# in Edge Functions + the database, so set them there, not here:
#   Edge Function secrets (supabase secrets set):
#     TERMII_API_KEY=...           (Termii API key)
#     TERMII_SENDER_ID=Locumii     (registered sender ID)
#   Supabase Vault secrets (one-time SQL, used by private.dispatch_sms / the cron):
#     project_url        = https://<project-ref>.supabase.co
#     service_role_key   = <service role key>
# See supabase/migrations/027_sms_dispatch.sql and 029_schedule_shift_reminders.sql.
